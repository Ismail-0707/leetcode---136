class Solution
{
    public int singleNumber(int[] nums) 
    {
        HashSet<Integer> h = new HashSet<>();
        for(int i=0;i<nums.length;i++)
        {
            if(!h.contains(nums[i]))
            {
                h.add(nums[i]);
            }
            else
            {
                h.remove(nums[i]);
            }
        }  
        return h.iterator().next();  
    }
}
